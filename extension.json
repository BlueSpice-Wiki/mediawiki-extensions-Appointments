{
	"name": "Appointments",
	"version": "1.0.0-alpha",
	"license-name": "GPL-3.0-only",
	"author": [
		"[https://www.hallowelt.com Hallo Welt! GmbH]"
	],
	"url": "https://www.mediawiki.org/wiki/Extension:Appointments",
	"descriptionmsg": "appointments-desc",
	"requires": {
		"MediaWiki": ">= 1.43.0"
	},
	"attributes": {
	},
	"callback": "mwsInitComponents",
	"MessagesDirs": {
		"Appointments": "i18n"
	},
	"ExtensionMessagesFiles": {
		"AppointmentsAlias": "Appointments.alias.php"
	},
	"AutoloadNamespaces": {
		"MediaWiki\\Extension\\Appointments\\": "src/",
		"MediaWiki\\Extension\\Appointments\\Tests\\": "tests/phpunit"
	},
	"ResourceModules": {
		"ext.appointments.main": {
			"packageFiles": [
				"bootstrap.js",
				"api.js",
				"ui/Scheduler.js",
				"ui/CalendarMultiselect.js",
				"ui/CalendarPicker.js",
				"ui/EditorDialog.js",
				"ui/CalendarEditor.js",
				"ui/AppointmentEditor.js",
				"ui/util/NewCalendarMenuOption.js",
				"ui/util/CalendarMenuOption.js",
				"object/PeriodDefinition.js",
				"object/Participant.js",
				"object/Calendar.js",
				"object/Appointment.js"
			],
			"messages": [
				"appointments-ui-create-new-calendar",
				"appointments-ui-field-calendar-name",
				"appointments-ui-field-calendar-description",
				"appointments-ui-edit-calendar",
				"appointments-ui-create-calendar",
				"appointments-ui-save",
				"appointments-ui-cancel"
			],
			"dependencies": [
				"oojs-ui",
				"ext.appointments.lib.calendarjs"
			]
		},
		"ext.appointments.lib.calendarjs": {
			"packageFiles": [
				"lib/calendarjs/index.min.js",
				"lib/calendarjs/lemonade.min.js"
			],
			"styles": [
				"lib/calendarjs/style.min.css"
			]
		},
		"ext.appointments.special": {
			"packageFiles": [
				"specialPage.js"
			],
			"dependencies": [
				"ext.appointments.main"
			],
			"styles": [
				"styles.less"
			]
		}
	},
	"ResourceFileModulePaths": {
		"localBasePath": "resources",
		"remoteExtPath": "Appointments/resources"
	},
	"Hooks": {
		"LoadExtensionSchemaUpdates": "runDatabaseUpdates"
	},
	"HookHandlers": {
		"runDatabaseUpdates": {
			"class": "MediaWiki\\Extension\\Appointments\\Hook\\RunDatabaseUpdates"
		}
	},
	"ServiceWiringFiles": [
		"includes/ServiceWiring.php"
	],
	"SpecialPages": {
		"Appointments": {
			"class": "MediaWiki\\Extension\\Appointments\\AppointmentsSpecial"
		}
	},
	"RestRoutes": [
		{
			"method": "GET",
			"path": "/appointments/v0/appointments",
			"class": "MediaWiki\\Extension\\Appointments\\Rest\\AppointmentGetHandler",
			"services": [ "Appointments.CalendarStore", "Appointments.AppointmentStore" ]
		},
		{
			"method": "GET",
			"path": "/appointments/v0/calendars",
			"class": "MediaWiki\\Extension\\Appointments\\Rest\\CalendarGetHandler",
			"services": [ "Appointments.CalendarStore" ]
		},
		{
			"method": "POST",
			"path": "/appointments/v0/appointment",
			"class": "MediaWiki\\Extension\\Appointments\\Rest\\AppointmentSaveHandler",
			"services": [
				"Appointments.AppointmentStore", "Appointments._UserInterface",
				"Appointments._Permissions", "Appointments._ParticipantResolver",
				"HookContainer", "Appointments._Logger"
			]
		},
		{
			"method": "POST",
			"path": "/appointments/v0/appointment/delete/{appointment}",
			"class": "MediaWiki\\Extension\\Appointments\\Rest\\AppointmentDeleteHandler",
			"services": [
				"Appointments.AppointmentStore", "Appointments._Permissions", "HookContainer", "Appointments._Logger"
			]
		},
		{
			"method": "POST",
			"path": "/appointments/v0/calendar",
			"class": "MediaWiki\\Extension\\Appointments\\Rest\\CalendarSaveHandler",
			"services": [
				"Appointments.CalendarStore", "Appointments._Permissions", "HookContainer", "Appointments._Logger"
			]
		},
		{
			"method": "POST",
			"path": "/appointments/v0/calendar/delete/{calendar}",
			"class": "MediaWiki\\Extension\\Appointments\\Rest\\CalendarDeleteHandler",
			"services": [
				"Appointments.CalendarStore", "Appointments.AppointmentStore",
				"Appointments._Permissions", "HookContainer", "Appointments._Logger"
			]
		}
	],
	"manifest_version": 2,
	"load_composer_autoloader": true
}
