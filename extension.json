{
	"name": "Appointments",
	"version": "1.0.0-alpha",
	"license-name": "GPL-3.0-only",
	"author": [
		"[https://www.hallowelt.com Hallo Welt! GmbH]"
	],
	"url": "https://www.mediawiki.org/wiki/Extension:Appointments",
	"descriptionmsg": "appointments-desc",
	"requires": {
		"MediaWiki": ">= 1.43.0",
		"extensions": {
			"OOJSPlus": "*"
		}
	},
	"attributes": {
		"Appointments": {
			"EventTypes": {
				"birthday": {
					"class": "MediaWiki\\Extension\\Appointments\\Entity\\EventType\\Birthday"
				},
				"meeting": {
					"class": "MediaWiki\\Extension\\Appointments\\Entity\\EventType\\Meeting"
				},
				"travel": {
					"class": "MediaWiki\\Extension\\Appointments\\Entity\\EventType\\Travel"
				},
				"vacation": {
					"class": "MediaWiki\\Extension\\Appointments\\Entity\\EventType\\Vacation"
				}
			}
		}
	},
	"callback": "mwsInitComponents",
	"MessagesDirs": {
		"Appointments": "i18n"
	},
	"ExtensionMessagesFiles": {
		"AppointmentsAlias": "Appointments.alias.php"
	},
	"AutoloadNamespaces": {
		"MediaWiki\\Extension\\Appointments\\": "src/",
		"MediaWiki\\Extension\\Appointments\\Tests\\": "tests/phpunit"
	},
	"ResourceModules": {
		"ext.appointments.main": {
			"packageFiles": [
				"bootstrap.js",
				"api.js",
				"ui/Scheduler.js",
				"ui/CalendarMultiselect.js",
				"ui/EventTypeMultiselect.js",
				"ui/CalendarPicker.js",
				"ui/EventTypePicker.js",
				"ui/EditorDialog.js",
				"ui/CalendarEditor.js",
				"ui/EventTypeEditor.js",
				"ui/AppointmentEditor.js",
				"ui/AppointmentEntry.js",
				"ui/AppointmentViewer.js",
				"ui/SchedulerWeekDayView.js",
				"ui/SchedulerMonthView.js",
				"ui/util/NewCalendarMenuOption.js",
				"ui/util/EventTypeMenuOptions.js",
				"ui/util/AppointmentTime.js",
				"ui/util/TimePicker.js",
				"ui/util/AppointmentTimeView.js",
				"ui/util/ParticipantView.js",
				"ui/util/CalendarCheckboxMenuOption.js",
				"ui/util/MainToolbar.js",
				"ui/util/EntityColor.js",
				"ui/util/PanelWithEvents.js",
				"ui/util/AppointmentPopupList.js",
				"ui/util/EventTypeIcon.js",
				"object/PeriodDefinition.js",
				"object/Participant.js",
				"object/Calendar.js",
				"object/Appointment.js",
				"object/EventType.js",
				"object/eventType/Meeting.js",
				"CalendarDataProvider.js",
				"UserLocalPreferences.js",
				{
					"name": "config.json",
					"callback": "MediaWiki\\Extension\\Appointments\\ResourceLoader\\ConfigCallback::handleConfigRequest"
				}
			],
			"messages": [
				"appointments-ui-create-new-calendar",
				"appointments-ui-new-appointment",
				"appointments-ui-calendars",
				"appointments-ui-field-calendar-name",
				"appointments-ui-field-calendar-description",
				"appointments-ui-field-calendar-event-types",
				"appointments-ui-field-appointment-name",
				"appointments-ui-field-event-type",
				"appointments-ui-field-participants",
				"appointments-ui-field-notify-in-advance",
				"appointments-ui-field-location",
				"appointments-ui-field-video-link",
				"appointments-ui-field-time",
				"appointments-ui-date",
				"appointments-ui-time-start",
				"appointments-ui-time-end",
				"appointments-ui-date-start",
				"appointments-ui-date-end",
				"appointments-ui-all-day",
				"appointments-ui-recurrence",
				"appointments-ui-recurrence-none",
				"appointments-ui-recurrence-daily",
				"appointments-ui-recurrence-weekly",
				"appointments-ui-recurrence-monthly",
				"appointments-ui-edit-calendar",
				"appointments-ui-create-calendar",
				"appointments-ui-edit-event-type",
				"appointments-ui-create-event-type",
				"appointments-ui-edit-appointment",
				"appointments-ui-create-appointment",
				"appointments-ui-save",
				"appointments-ui-cancel",
				"appointments-ui-field-participants-placeholder",
				"appointments-ui-calendar-options",
				"appointments-ui-entity-type-options",
				"appointments-ui-edit",
				"appointments-ui-delete",
				"appointments-next-period",
				"appointments-previous-period",
				"appointments-next-month",
				"appointments-previous-month",
				"appointments-ui-delete-appointment-confirmation",
				"appointments-ui-delete-appointment-failed",
				"appointments-ui-delete-calendar",
				"appointments-ui-delete-calendar-confirmation",
				"appointments-ui-delete-calendar-failed",
				"appointments-ui-delete-event-type",
				"appointments-ui-delete-event-type-confirmation",
				"appointments-ui-delete-event-type-failed",
				"appointments-ui-load-calendars-failed",
				"appointments-ui-load-calendar-failed",
				"appointments-ui-recurrence-yearly",
				"appointments-ui-recurring-appointment",
				"appointments-ui-view-day",
				"appointments-ui-view-week",
				"appointments-ui-view-month",
				"appointments-more-appointments",
				"appointments-view-appointment",
				"appointments-ui-video-link-join",
				"appointments-ui-field-entity-type-name",
				"appointments-ui-field-entity-type-description",
				"appointments-ui-field-entity-type-color",
				"appointments-ui-create-new-event-type",
				"appointments-ui-select-event-type-icon",
				"appointments-ui-field-entity-type-icon"
			],
			"dependencies": [
				"oojs-ui",
				"ext.appointments.lib.calendarjs",
				"oojs-ui.styles.icons-location",
				"oojs-ui.styles.icons-media",
				"oojs-ui.styles.icons-interactions",
				"oojs-ui.styles.icons-editing-advanced",
				"oojs-ui.styles.icons-editing-core",
				"ext.oOJSPlus.widgets"
			]
		},
		"ext.appointments.lib.calendarjs": {
			"packageFiles": [
				"lib/calendarjs/index.min.js",
				"lib/calendarjs/lemonade.min.js"
			],
			"styles": [
				"lib/calendarjs/style.min.css"
			]
		},
		"ext.appointments.special": {
			"packageFiles": [
				"specialPage.js"
			],
			"dependencies": [
				"ext.appointments.main"
			],
			"styles": [
				"styles.less"
			]
		}
	},
	"ResourceFileModulePaths": {
		"localBasePath": "resources",
		"remoteExtPath": "Appointments/resources"
	},
	"Hooks": {
		"LoadExtensionSchemaUpdates": "runDatabaseUpdates",
		"BeforePageDisplay": "addJSVariables"
	},
	"HookHandlers": {
		"runDatabaseUpdates": {
			"class": "MediaWiki\\Extension\\Appointments\\Hook\\RunDatabaseUpdates"
		},
		"addJSVariables": {
			"class": "MediaWiki\\Extension\\Appointments\\Hook\\AddJSVariables",
			"services": [ "Appointments._Permissions" ]
		}
	},
	"ServiceWiringFiles": [
		"includes/ServiceWiring.php"
	],
	"SpecialPages": {
		"Appointments": {
			"class": "MediaWiki\\Extension\\Appointments\\AppointmentsSpecial"
		}
	},
	"RestRoutes": [
		{
			"method": "GET",
			"path": "/appointments/v0/appointments",
			"class": "MediaWiki\\Extension\\Appointments\\Rest\\AppointmentsGetHandler",
			"services": [
				"Appointments.CalendarStore", "Appointments.AppointmentStore", "Appointments.EventTypeStore",
				"Appointments._UserInterface", "Appointments._Permissions"
			]
		},
		{
			"method": "GET",
			"path": "/appointments/v0/appointment/{guid}",
			"class": "MediaWiki\\Extension\\Appointments\\Rest\\AppointmentGetHandler",
			"services": [
				"Appointments.AppointmentStore", "Appointments._UserInterface", "Appointments._Permissions"
			]
		},
		{
			"method": "GET",
			"path": "/appointments/v0/calendars",
			"class": "MediaWiki\\Extension\\Appointments\\Rest\\CalendarGetHandler",
			"services": [ "Appointments.CalendarStore", "Appointments._Permissions" ]
		},
		{
			"method": "GET",
			"path": "/appointments/v0/event_types",
			"class": "MediaWiki\\Extension\\Appointments\\Rest\\EventTypeGetHandler",
			"services": [ "Appointments.EventTypeStore" ]
		},
		{
			"method": "POST",
			"path": "/appointments/v0/appointment",
			"class": "MediaWiki\\Extension\\Appointments\\Rest\\AppointmentSaveHandler",
			"services": [
				"Appointments.CalendarStore", "Appointments.AppointmentStore",  "Appointments.EventTypeStore",
				"Appointments._UserInterface", "Appointments._Permissions", "Appointments._ParticipantResolver",
				"HookContainer", "Appointments._Logger"
			]
		},
		{
			"method": "POST",
			"path": "/appointments/v0/appointment/delete/{appointment}",
			"class": "MediaWiki\\Extension\\Appointments\\Rest\\AppointmentDeleteHandler",
			"services": [
				"Appointments.AppointmentStore", "Appointments._Permissions", "HookContainer", "Appointments._Logger"
			]
		},
		{
			"method": "POST",
			"path": "/appointments/v0/calendar",
			"class": "MediaWiki\\Extension\\Appointments\\Rest\\CalendarSaveHandler",
			"services": [
				"Appointments.CalendarStore", "Appointments.EventTypeStore",
				"Appointments._Permissions", "HookContainer", "Appointments._Logger"
			]
		},
		{
			"method": "POST",
			"path": "/appointments/v0/calendar/delete/{calendar}",
			"class": "MediaWiki\\Extension\\Appointments\\Rest\\CalendarDeleteHandler",
			"services": [
				"Appointments.CalendarStore", "Appointments.AppointmentStore",
				"Appointments._Permissions", "HookContainer", "Appointments._Logger"
			]
		},
		{
			"method": "POST",
			"path": "/appointments/v0/event_type",
			"class": "MediaWiki\\Extension\\Appointments\\Rest\\EventTypeSaveHandler",
			"services": [
				"Appointments.EventTypeStore", "Appointments._Permissions", "Appointments._Logger"
			]
		},
		{
			"method": "POST",
			"path": "/appointments/v0/event_type/delete/{eventType}",
			"class": "MediaWiki\\Extension\\Appointments\\Rest\\EventTypeSaveHandler",
			"services": [
				"Appointments.EventTypeStore", "Appointments._Permissions", "Appointments._Logger"
			]
		}
	],
	"manifest_version": 2,
	"load_composer_autoloader": true
}
