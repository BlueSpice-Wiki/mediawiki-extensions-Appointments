{
	"name": "Appointments",
	"version": "1.0.0-alpha",
	"license-name": "GPL-3.0-only",
	"author": [
		"[https://www.hallowelt.com Hallo Welt! GmbH]"
	],
	"url": "https://www.mediawiki.org/wiki/Extension:Appointments",
	"descriptionmsg": "appointments-desc",
	"requires": {
		"MediaWiki": ">= 1.43.0",
		"extensions": {
			"OOJSPlus": "*"
		}
	},
	"attributes": {
		"Appointments": {
			"EventTypes": {
				"birthday": {
					"class": "MediaWiki\\Extension\\Appointments\\Entity\\EventType\\Birthday"
				},
				"meeting": {
					"class": "MediaWiki\\Extension\\Appointments\\Entity\\EventType\\Meeting"
				},
				"travel": {
					"class": "MediaWiki\\Extension\\Appointments\\Entity\\EventType\\Travel"
				},
				"vacation": {
					"class": "MediaWiki\\Extension\\Appointments\\Entity\\EventType\\Vacation"
				}
			}
		},
		"BlueSpiceFoundation": {
			"PermissionRegistry": {
				"manage-appointments": {
					"type": "global",
					"roles": [ "editor", "admin" ]
				},
				"change-appointment-permissions": {
					"type": "global",
					"roles": [ "admin" ]
				}
			},
			"ConfigDefinitionRegistry": {
				"AppointmentsShowInMainLinks": "\\MediaWiki\\Extension\\Appointments\\ConfigDefinition\\MainLinksAppointments::getInstance"
			}
		},
		"NotifyMe": {
			"Events": {
				"appointments-assignment": {
					"spec": {
						"class": "\\MediaWiki\\Extension\\Appointments\\Event\\AppointmentAssignedEvent"
					},
					"buckets": [ "personal" ],
					"description": "appointments-event-assign-desc"
				},
				"appointments-reminder": {
					"spec": {
						"class": "\\MediaWiki\\Extension\\Appointments\\Event\\AppointmentReminderEvent"
					},
					"buckets": [ "personal" ],
					"description": "appointments-event-remind-desc"
				}
			}
		}
	},
	"callback": "mwsInitComponents",
	"MessagesDirs": {
		"Appointments": "i18n"
	},
	"AvailableRights": [
		"manage-appointments",
		"change-appointment-permissions"
	],
	"GroupPermissions": {
		"sysop": {
			"manage-appointments": true,
			"change-appointment-permissions": true
		}
	},
	"ExtensionMessagesFiles": {
		"AppointmentsAlias": "Appointments.alias.php"
	},
	"AutoloadNamespaces": {
		"MediaWiki\\Extension\\Appointments\\": "src/",
		"MediaWiki\\Extension\\Appointments\\Tests\\": "tests/phpunit"
	},
	"ResourceModules": {
		"ext.appointments.main": {
			"packageFiles": [
				"bootstrap.js",
				"consts.js",
				"api.js",
				"ui/Scheduler.js",
				"ui/CalendarMultiselect.js",
				"ui/EventTypeMultiselect.js",
				"ui/CalendarPicker.js",
				"ui/EventTypePicker.js",
				"ui/EditorDialog.js",
				"ui/CalendarEditor.js",
				"ui/EventTypeEditor.js",
				"ui/AppointmentEditor.js",
				"ui/AppointmentEntry.js",
				"ui/AppointmentViewer.js",
				"ui/SchedulerView.js",
				"ui/CalendarPermissionEditor.js",
				"ui/util/NewCalendarMenuOption.js",
				"ui/util/EventTypeMenuOptions.js",
				"ui/util/AppointmentTime.js",
				"ui/util/TimePicker.js",
				"ui/util/AppointmentTimeView.js",
				"ui/util/ParticipantView.js",
				"ui/util/CalendarCheckboxMenuOption.js",
				"ui/util/MainToolbar.js",
				"ui/util/EntityColor.js",
				"ui/util/PanelWithEvents.js",
				"ui/util/AppointmentPopupList.js",
				"ui/util/EventTypeIcon.js",
				"ui/util/NotifyInAdvancePicker.js",
				"object/PeriodDefinition.js",
				"object/Participant.js",
				"object/Calendar.js",
				"object/Appointment.js",
				"object/EventType.js",
				"object/eventType/Meeting.js",
				"CalendarDataProvider.js",
				"UserLocalPreferences.js"
			],
			"messages": [
				"appointments-ui-create-new-calendar",
				"appointments-ui-error-saving-appointment",
				"appointments-ui-new-appointment",
				"appointments-ui-field-calendar-name",
				"appointments-ui-field-calendar-description",
