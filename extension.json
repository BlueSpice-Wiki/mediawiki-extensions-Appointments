				"appointments-ui-notify-1h",
				"appointments-ui-notify-3h",
				"appointments-ui-notify-day",
				"appointments-ui-notify-week",
				"appointments-ui-calendar-permissions",
				"appointments-ui-calendar-permissions-nothing",
				"appointments-ui-calendar-permissions-edit",
				"appointments-ui-calendar-permissions-read-edit",
				"appointments-ui-calendar-permissions-role-reader",
				"appointments-ui-calendar-permissions-role-editor",
				"appointments-ui-calendar-permissions-role-deleter",
				"appointments-ui-edit-calendar-permissions",
				"appointments-ui-calendar-permissions-role-reader-placeholder",
				"appointments-ui-calendar-permissions-role-edit-delete-placeholder",
				"appointments-ui-calendar-permissions-disclaimer",
				"appointments-ui-calendar-picker-none"
			],
			"dependencies": [
				"oojs-ui",
				"ext.appointments.lib.fullcalendar",
				"oojs-ui.styles.icons-location",
				"oojs-ui.styles.icons-media",
				"oojs-ui.styles.icons-interactions",
				"oojs-ui.styles.icons-editing-advanced",
				"oojs-ui.styles.icons-editing-core",
				"ext.oOJSPlus.widgets"
			],
			"styles": [
				"styles.less"
			]
		},
		"ext.appointments.lib.fullcalendar": {
			"scripts": [
				"lib/fullcalendar/index.global.min.js",
				"lib/fullcalendar/export.js"
			]
		},
		"ext.appointments.timeline.tag": {
			"packageFiles": [
				"tag.js",
				"formelement/CalendarPicker.js",
				"formelement/EventTypePicker.js",
				"ui/util/EventTypeMenuOptions.js",
				"ui/CalendarPicker.js",
				"ui/EventTypePicker.js"
			],
			"dependencies": [
				"ext.appointments.main",
				"ext.forms.formelements.bootstrap",
				"ext.oOJSPlus.formelements"
			]
		},
		"ext.appointments.special": {
			"packageFiles": [
				"specialPage.js"
			],
			"dependencies": [
				"ext.appointments.main"
			]
		}
	},
	"ResourceFileModulePaths": {
		"localBasePath": "resources",
		"remoteExtPath": "Appointments/resources"
	},
	"Hooks": {
		"LoadExtensionSchemaUpdates": "runDatabaseUpdates",
		"BeforePageDisplay": "addJSVariables",
		"MWStakeCommonUIRegisterSkinSlotComponents": "addLinks",
		"SkinTemplateNavigation::Universal": "addLinks",
		"AppointmentsAppointmentModified": "sendNotifications",
		"AppointmentsAppointmentCreated": "sendNotifications",
		"MediaWikiServices": "registerCron",
		"MWStakeGenericTagHandlerInitTags": "registerTags"
	},
	"HookHandlers": {
		"runDatabaseUpdates": {
			"class": "MediaWiki\\Extension\\Appointments\\Hook\\RunDatabaseUpdates"
		},
		"addJSVariables": {
			"class": "MediaWiki\\Extension\\Appointments\\Hook\\AddJSVariables",
			"services": [ "Appointments._Permissions", "Appointments._UserInterface" ]
		},
		"addLinks": {
			"class": "MediaWiki\\Extension\\Appointments\\Hook\\AddLinks",
			"services": [ "SpecialPageFactory", "MainConfig" ]
		},
		"sendNotifications": {
			"class": "MediaWiki\\Extension\\Appointments\\Hook\\SendNotificationsOnUpdate",
			"services": [ "Appointments._UserResolver", "MWStake.Notifier", "SpecialPageFactory", "ContentLanguage" ]
		},
		"registerCron": {
			"class": "MediaWiki\\Extension\\Appointments\\Hook\\RegisterCron"
		},
		"registerTags": {
			"class": "MediaWiki\\Extension\\Appointments\\Hook\\AddTag",
			"services": [ "UserFactory", "Appointments.CalendarStore", "Appointments.EventTypeStore" ]
		}
	},
	"ServiceWiringFiles": [
		"includes/ServiceWiring.php"
	],
	"SpecialPages": {
		"Appointments": {
			"class": "MediaWiki\\Extension\\Appointments\\AppointmentsSpecial"
		}
	},
	"RestRoutes": [
		{
			"method": "GET",
			"path": "/appointments/v0/appointments",
			"class": "MediaWiki\\Extension\\Appointments\\Rest\\AppointmentsGetHandler",
			"services": [
				"Appointments.CalendarStore", "Appointments.AppointmentStore", "Appointments.EventTypeStore",
				"Appointments._UserInterface", "Appointments._AppointmentSerializer"
			]
		},
		{
			"method": "GET",
			"path": "/appointments/v0/appointment/{guid}",
			"class": "MediaWiki\\Extension\\Appointments\\Rest\\AppointmentGetHandler",
			"services": [
				"Appointments.AppointmentStore", "Appointments._AppointmentSerializer"
			]
		},
		{
			"method": "GET",
			"path": "/appointments/v0/calendars",
			"class": "MediaWiki\\Extension\\Appointments\\Rest\\CalendarGetHandler",
			"services": [ "Appointments.CalendarStore", "Appointments._Permissions" ]
		},
		{
			"method": "GET",
			"path": "/appointments/v0/event_types",
			"class": "MediaWiki\\Extension\\Appointments\\Rest\\EventTypeGetHandler",
			"services": [ "Appointments.EventTypeStore" ]
		},
		{
			"method": "POST",
			"path": "/appointments/v0/appointment",
			"class": "MediaWiki\\Extension\\Appointments\\Rest\\AppointmentSaveHandler",
			"services": [
				"Appointments.CalendarStore", "Appointments.AppointmentStore",  "Appointments.EventTypeStore",
				"Appointments._UserInterface", "Appointments._Permissions", "Appointments._UserResolver",
				"HookContainer", "Appointments._Logger", "Appointments._AgendaLinker"
			]
		},
		{
			"method": "POST",
			"path": "/appointments/v0/appointment/delete/{appointment}",
			"class": "MediaWiki\\Extension\\Appointments\\Rest\\AppointmentDeleteHandler",
			"services": [
				"Appointments.AppointmentStore", "Appointments._Permissions", "HookContainer", "Appointments._Logger"
			]
		},
		{
			"method": "POST",
			"path": "/appointments/v0/calendar",
			"class": "MediaWiki\\Extension\\Appointments\\Rest\\CalendarSaveHandler",
			"services": [
				"Appointments.CalendarStore", "Appointments.EventTypeStore",
				"Appointments._Permissions", "HookContainer", "Appointments._Logger"
			]
		},
		{
			"method": "POST",
			"path": "/appointments/v0/calendar/delete/{calendar}",
			"class": "MediaWiki\\Extension\\Appointments\\Rest\\CalendarDeleteHandler",
			"services": [
				"Appointments.CalendarStore", "Appointments.AppointmentStore",
				"Appointments._Permissions", "HookContainer", "Appointments._Logger"
			]
		},
		{
			"method": "POST",
			"path": "/appointments/v0/event_type",
			"class": "MediaWiki\\Extension\\Appointments\\Rest\\EventTypeSaveHandler",
			"services": [
				"Appointments.EventTypeStore", "Appointments._Permissions", "Appointments._Logger"
			]
		},
		{
			"method": "POST",
			"path": "/appointments/v0/event_type/delete/{eventType}",
			"class": "MediaWiki\\Extension\\Appointments\\Rest\\EventTypeSaveHandler",
			"services": [
				"Appointments.EventTypeStore", "Appointments._Permissions", "Appointments._Logger"
			]
		}
	],
	"config": {
		"AppointmentsShowInMainLinks": {
			"value": true,
			"description": "Whether to show the link to the Appointments special page in the main links section of the user interface."
		}
	},
	"manifest_version": 2,
	"load_composer_autoloader": true
}
