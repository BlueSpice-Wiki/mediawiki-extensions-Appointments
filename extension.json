				"appointments-ui-delete-calendar",
				"appointments-ui-delete-calendar-confirmation",
				"appointments-ui-delete-calendar-failed",
				"appointments-ui-delete-event-type",
				"appointments-ui-delete-event-type-confirmation",
				"appointments-ui-delete-event-type-failed",
				"appointments-ui-load-calendars-failed",
				"appointments-ui-load-calendar-failed",
				"appointments-ui-recurrence-yearly",
				"appointments-ui-recurring-appointment",
				"appointments-ui-view-day",
				"appointments-ui-view-week",
				"appointments-ui-view-month",
				"appointments-ui-view-year",
				"appointments-view-appointment",
				"appointments-ui-video-link-join",
				"appointments-ui-field-entity-type-name",
				"appointments-ui-field-entity-type-description",
				"appointments-ui-field-entity-type-color",
				"appointments-ui-create-new-event-type",
				"appointments-ui-select-event-type-icon",
